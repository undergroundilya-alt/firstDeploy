# Render single web service beta setup for AdProof.
# No separate PostgreSQL/Redis service is required for this temporary trial build.
# Data is stored in JSON files under STORAGE_ROOT.
# IMPORTANT: without a persistent disk, this storage can be reset after redeploy/restart.

NODE_ENV=production
USE_HTTPS=false
HOST=0.0.0.0
TRUST_PROXY=true
PUBLIC_BASE_URL=https://YOUR_RENDER_WEB_SERVICE.onrender.com

# Single-service JSON storage
STORAGE_ROOT=/opt/render/project/src/storage
DATA_FILE=/opt/render/project/src/storage/saas-state.json
AUTH_DB_FILE=/opt/render/project/src/storage/auth-accounts.json
RUNTIME_FILE=/opt/render/project/src/storage/runtime-sessions.json
LEADS_FILE=/opt/render/project/src/storage/leads.json
EMAIL_OUTBOX_FILE=/opt/render/project/src/storage/email-outbox.json
BACKUP_DIR=/opt/render/project/src/storage/backups
EVENT_LOG_DIR=/opt/render/project/src/storage/events
AUDIT_LOG_DIR=/opt/render/project/src/storage/audit
ALERT_LOG_DIR=/opt/render/project/src/storage/alerts
DEAD_LETTER_DIR=/opt/render/project/src/storage/dead-letter
CORRUPTED_DIR=/opt/render/project/src/storage/corrupted

# Disable external DB/Redis for one-service Render trial
ENABLE_APP_DB=false
ENABLE_POSTGRES_STORAGE=false
AUTH_REQUIRE_DATABASE_FOR_CLIENT_AUTH=false
CLUSTER_MODE=false
ENABLE_REDIS_RUNTIME=false
ENABLE_REDIS_EVENT_QUEUE=false

# Beta-friendly startup
STRICT_PRODUCTION_GUARD=false
REQUIRE_MFA_IN_PRODUCTION=false
DOCS_PRIVATE=false
METRICS_REQUIRE_TOKEN_IN_PRODUCTION=false
SMTP_ENABLED=false
AUTH_DEBUG_LOGS=true

# Set real values in Render Environment
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD_14_CHARS_MIN
SESSION_SECRET=CHANGE_THIS_LONG_RANDOM_SECRET_32_CHARS_MIN
ENCRYPTION_KEY=CHANGE_THIS_LONG_RANDOM_SECRET_32_CHARS_MIN
METRICS_TOKEN=CHANGE_THIS_LONG_RANDOM_TOKEN_32_CHARS_MIN

# Optional Google OAuth later
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
