# AdProof DB-first mode.
# Copy to .env and paste your real Render PostgreSQL URL below.
# Do NOT commit .env with real credentials.

NODE_ENV=development
HOST=0.0.0.0
PORT=3443
USE_HTTPS=false
PUBLIC_BASE_URL=http://localhost:3443

ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-to-a-long-random-string-32-plus-chars
ENCRYPTION_KEY=change-this-to-a-long-random-string-32-plus-chars

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE
POSTGRES_SSL=true
ENABLE_APP_DB=true
ENABLE_POSTGRES_STORAGE=true
AUTH_REQUIRE_DATABASE_FOR_CLIENT_AUTH=true
POSTGRES_AUTO_MIGRATE=true
POSTGRES_BOOTSTRAP_FROM_JSON=true
POSTGRES_DIRECT_EVENT_WRITE=true
POSTGRES_SYNC_CONFIG=true
POSTGRES_SYNC_ANALYTICS=true

# DB is the source of truth. Disable local temporary JSON event/state writes.
PERSIST_EVENT_STATS_IN_JSON=false
LOCAL_EVENT_LOG_ENABLED=false
LOCAL_STATE_WRITE_ENABLED=false
LOCAL_RUNTIME_WRITE_ENABLED=false
KEEP_IN_MEMORY_EVENT_STATS=true

# No Redis for this single local/Render beta service.
CLUSTER_MODE=false
ENABLE_REDIS_RUNTIME=false
ENABLE_REDIS_EVENT_QUEUE=false

# Local testing convenience.
STRICT_PRODUCTION_GUARD=false
REQUIRE_MFA_IN_PRODUCTION=false
DOCS_PRIVATE=false
METRICS_REQUIRE_TOKEN_IN_PRODUCTION=false
SMTP_ENABLED=false
AUTH_DEBUG_LOGS=true
