# AdProof staging environment example
# Use a separate staging Render/Postgres database here. Do not point this to production.
APP_ENV=staging
NODE_ENV=staging
USE_HTTPS=false
PUBLIC_BASE_URL=http://localhost:3443

DATABASE_URL=postgresql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST/STAGING_DB
POSTGRES_URL=postgresql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST/STAGING_DB
ENABLE_APP_DB=true
ENABLE_POSTGRES_STORAGE=true
POSTGRES_DIRECT_EVENT_WRITE=true
POSTGRES_AUTO_MIGRATE=true
POSTGRES_SSL=true
AUTH_REQUIRE_DATABASE_FOR_CLIENT_AUTH=true

ALLOW_MOCK_DATA=true
SEED_DAYS=90
SEED_CLEAR=true
