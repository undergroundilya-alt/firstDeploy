# AVP v1.9 commercial beta — local development example
NODE_ENV=development
HOST=0.0.0.0
PORT=3443
PUBLIC_BASE_URL=https://localhost:3443
USE_HTTPS=true

ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-me-to-random-64-chars
ENCRYPTION_KEY=change-me-to-random-64-chars

# Use STORAGE_ROOT for one persistent root; override individual paths only when needed.
STORAGE_ROOT=./storage
DATA_FILE=./storage/saas-state.json
RUNTIME_FILE=./storage/runtime-sessions.json
BACKUP_DIR=./storage/backups
EVENT_LOG_DIR=./storage/events
AUDIT_LOG_DIR=./storage/audit
ALERT_LOG_DIR=./storage/alerts
DEAD_LETTER_DIR=./storage/dead-letter
CORRUPTED_DIR=./storage/corrupted

# Optional external backup target. Use EXTERNAL_BACKUP_DIR for mounted/object-sync folder,
# or EXTERNAL_BACKUP_COMMAND=/path/to/upload-script which receives the backup file path as argv[1].
EXTERNAL_BACKUP_DIR=
EXTERNAL_BACKUP_COMMAND=

EVENT_LOG_RETENTION_DAYS=90
OLD_EVENT_LOG_GZIP_AFTER_DAYS=14
BACKUP_INTERVAL_MS=21600000
RESTORE_DRILL_INTERVAL_MS=86400000
BACKUP_RETENTION=24
MAX_GLOBAL_RECENT_EVENTS=1000
MAX_RECENT_PROJECT_EVENTS=300
EVENT_WRITE_QUEUE_LIMIT=5000

DOCS_PRIVATE=false
METRICS_TOKEN=
METRICS_REQUIRE_TOKEN_IN_PRODUCTION=true
METRICS_ALLOW_IPS=127.0.0.1,::1
TRUST_PROXY_IPS=127.0.0.1,::1
STRICT_PRODUCTION_GUARD=true
REQUIRE_MFA_IN_PRODUCTION=false
ALLOW_BOOT_WITHOUT_MFA=1
GLOBAL_KILL_SWITCH=false

DEFAULT_SDK_VERSION=v1
DEFAULT_SDK_CHANNEL=stable
CANARY_PERCENT=0

MAX_EVENTS_PER_PROJECT_PER_MINUTE=600
MAX_SESSIONS_PER_PROJECT_PER_MINUTE=120
MAX_PROOF_ATTEMPTS_PER_VISITOR=8
MAX_EVENTS_PER_VISITOR_PER_MINUTE=120
SIGNED_EVENTS_STRICT=false
API_LIMIT_MAX=240
VISITOR_SESSION_TTL_MS=7200000

# Client portal / app DB for Render/PostgreSQL
# When DATABASE_URL or POSTGRES_URL is configured, registration, Google OAuth, sessions and reset tokens use Postgres.
# Without a database URL the app uses JSON fallback for local-only testing.
ENABLE_APP_DB=false
# DATABASE_URL=postgres://user:password@host:5432/dbname
POSTGRES_SSL=false
AUTH_REQUIRE_DATABASE_FOR_CLIENT_AUTH=false
CLIENT_SESSION_TTL_MS=604800000

# Client portal / OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# EMAIL_OUTBOX_FILE=./storage/email-outbox.json


# Local auth/reset debugging. Keep true while testing Google OAuth + password reset locally.
AUTH_DEBUG_LOGS=true

# Real SMTP email sending. Uncomment and fill to send real emails.
# When SMTP_HOST is set and SMTP_ENABLED is not forced to false, SMTP is enabled automatically.
# For Gmail use an App Password, not the regular account password.
# SMTP_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="AdProof <your-email@gmail.com>"
# SMTP_REPLY_TO=your-email@gmail.com
# SMTP_REQUIRE_TLS=true
# SMTP_TIMEOUT_MS=15000
# SMTP_FAIL_BLOCKS_AUTH=false
EMAIL_OUTBOX_FILE=./storage/email-outbox.json

ENABLE_POSTGRES_STORAGE=true
POSTGRES_AUTO_MIGRATE=true
POSTGRES_DIRECT_EVENT_WRITE=true
