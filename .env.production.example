# AdProof production environment example
APP_ENV=production
NODE_ENV=production

DATABASE_URL=postgresql://PROD_USER:PROD_PASSWORD@PROD_HOST/PROD_DB
POSTGRES_URL=postgresql://PROD_USER:PROD_PASSWORD@PROD_HOST/PROD_DB
ENABLE_APP_DB=true
ENABLE_POSTGRES_STORAGE=true
POSTGRES_DIRECT_EVENT_WRITE=true
POSTGRES_AUTO_MIGRATE=false
POSTGRES_SSL=true
AUTH_REQUIRE_DATABASE_FOR_CLIENT_AUTH=true

# Safety: mock/seed data must stay disabled in production.
ALLOW_MOCK_DATA=false
ALLOW_PRODUCTION_MOCK_SEED=false
